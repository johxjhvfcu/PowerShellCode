$SMTPServer = "webmail.hvfcu.org"
$From = "orion@hvfcu.org"

# Multiple recipients
$To = @(
    "porrl@hvfcu.org",
    "johxj@hvfcu.org"
)

$Subject = "Vendors Expiring Within 20 Days"
$Body = "Attached is the latest expiring vendor report. Please review this report at your convenience. For those needing vendor extensions, please contact the Service Desk to inform them of the new date required so the user account isn't locked out by the reported date."

$Attachment = "C:\Automation\ExpiringUsers\UsersExpiringSoon.csv"

if (Test-Path $Attachment) {

    Send-MailMessage `
        -SmtpServer $SMTPServer `
        -From $From `
        -To $To `
        -Subject $Subject `
        -Body $Body `
        -Attachments $Attachment
}
else {

    Write-Host "Attachment not found: $Attachment"
    exit 1
}